{
  "name": "blop-wizard",
  "version": "0.1.2",
  "description": "CLI installer and runtime manager for the blop and blop-mcp release-confidence stack",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/n2400813g/blop-wizard.git"
  },
  "homepage": "https://github.com/n2400813g/blop-wizard#readme",
  "bugs": {
    "url": "https://github.com/n2400813g/blop-wizard/issues"
  },
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "blop-wizard": "dist/bin.js"
  },
  "scripts": {
    "build": "tsup",
    "check": "pnpm check:repo-hygiene && pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "check:repo-hygiene": "node check-repo-hygiene.mjs",
    "dev": "tsup --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm publish:check",
    "publish:check": "pnpm check && NPM_CONFIG_CACHE=/tmp/.npm-blop-wizard npm pack --dry-run --json",
    "start": "node dist/bin.js",
    "try": "pnpm build && node dist/bin.js --help",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run add-mcp-server-to-clients-flow.integration.test.ts add-mcp-server-to-clients-matrix.integration.test.ts",
    "lint": "eslint ."
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "blop",
    "mcp",
    "wizard",
    "cli",
    "cursor",
    "claude-code",
    "release-confidence",
    "release-testing"
  ],
  "author": "Blop",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "chalk": "^5.4.1",
    "dotenv": "^17.2.3",
    "jsonc-parser": "^3.3.1",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.5.2",
    "@types/yargs": "^17.0.33",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  }
}
